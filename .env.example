# Copy to .env and fill in your values

# Vapi — use your PRIVATE key (Dashboard → Account → API Keys → Private)
# Public key is only for browser/mobile SDKs — do not use it here
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# Groq — used by the LLM judge and eval runner (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Your public server URL (ngrok or deployed URL)
WEBHOOK_URL=https://your-app.up.railway.app/webhook/vapi
WEBHOOK_SECRET=optional_shared_secret

# Database — defaults to SQLite, swap for Postgres in production
DATABASE_URL=sqlite:///./clinic.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/clinic
